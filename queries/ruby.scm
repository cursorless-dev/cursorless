  name: (_) @name
  parameters: (_) @interior.start.endOf
  "end" @interior.end.startOf
) @namedFunction @name.domain

;;!! def foo end
;;!      ^^^
(method
  name: (_) @name @interior.start.endOf
  !parameters
  "end" @interior.end.startOf
) @namedFunction @name.domain

;;!! def foo.bar() end
;;!      ^^^
