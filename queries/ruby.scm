  .
  (rescue) @interior.end.startOf
)

;;!! begin end
(begin
  "begin" @branch.start @interior.start.endOf
  (_) @branch.end
  .
  "end" @interior.end.startOf
  (#not-type? @branch.end rescue)
) @branch.removal

;;!! rescue end
(begin
  (rescue
    "rescue" @interior.start.endOf
  ) @branch
