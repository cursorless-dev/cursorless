{
  "extends": ["../../.oxlintrc.json"],
  "overrides": [
    {
      "files": ["**/*.ts"],
      "rules": {
        "import/no-nodejs-modules": "warn"
      }
    },

    {
      "files": ["**/*.test.ts"],
      "rules": {
        "import/no-nodejs-modules": "off"
      }
    },

    {
      "files": ["src/types/command/**/*.ts"],
      "rules": {
        "@typescript-eslint/no-restricted-imports": [
          "warn",
          {
            "patterns": [
              {
                "group": ["@cursorless/*", "../*"],
                "message": "API types shouldn't have any dependencies"
              }
            ],
            "paths": [
              {
                "name": "@*",
                "message": "API types shouldn't have any dependencies"
              }
            ]
          }
        ]
      }
    }
  ]
}
