{
  "name": "@cursorless/cursorless-org",
  "version": "0.1.0",
  "description": "The cursorless.org website",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./out/index.js",
  "types": "./out/index.d.ts",
  "exports": {
    ".": {
      "cursorless:bundler": "./src/index.ts",
      "default": "./out/index.js"
    }
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "compile": "tsc --build",
    "watch": "tsc --build --watch",
    "clean": "rm -rf ./out tsconfig.tsbuildinfo ./dist ./build"
  },
  "dependencies": {
    "@cursorless/cheatsheet": "workspace:*",
    "@cursorless/common": "workspace:*",
    "react-dom": "^19.2.4",
    "react-player": "^3.4.0",
    "react": "^19.2.4",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react-dom": "^19.2.3",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.0.3",
    "http-server": "^14.1.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  }
}
