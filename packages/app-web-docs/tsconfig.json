{
  "extends": "../../tsconfig.web.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "skipLibCheck": true,
    "types": ["@docusaurus/theme-classic", "@docusaurus/module-type-aliases"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.json",
    "../../resources/typings/**/*.d.ts"
  ],
  "exclude": ["node_modules"]
}
