{
  "extends": ["@tsconfig/docusaurus/tsconfig.json", "../../tsconfig.web.json"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.json",
    "../../typings/**/*.d.ts"
  ],
  "exclude": ["node_modules"]
}
