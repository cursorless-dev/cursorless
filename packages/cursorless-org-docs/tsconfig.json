{
  "extends": ["@tsconfig/docusaurus/tsconfig.json", "../../tsconfig.base.json"],
  "compilerOptions": {
    "target": "es2022",
    "lib": ["dom", "es2022"],
    "jsx": "react",
    "esModuleInterop": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.json",
    "src/**/*.tsx",
    "../../typings/**/*.d.ts"
  ],
  "exclude": ["node_modules"]
}
