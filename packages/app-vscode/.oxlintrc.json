{
  "extends": ["../../.oxlintrc.json"],
  "ignorePatterns": ["src/keyboard/grammar/generated/**"],
  "overrides": [
    {
      "files": ["src/scripts/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "warn",
          {
            "paths": [
              {
                "name": "vscode",
                "message": "Scripts shouldn't depend on vscode"
              }
            ]
          }
        ]
      }
    }
  ]
}
