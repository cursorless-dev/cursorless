{
  "name": "@cursorless/lib-cheatsheet-local",
  "version": "0.1.0",
  "description": "Thin wrapper around the cheatsheet for showing local cheatsheet",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc",
    "clean": "rm -rf ./out ./dist ./tsconfig.tsbuildinfo",
    "test": "jest",
    "dev": "env NODE_OPTIONS=--import=tsx vite serve",
    "bundle:prod": "env NODE_OPTIONS=--import=tsx vite build",
    "bundle:dev": "env NODE_OPTIONS=--import=tsx vite build --mode development",
    "bundle:watch": "env NODE_OPTIONS=--import=tsx vite build --mode development --watch"
  },
  "dependencies": {
    "@cursorless/lib-cheatsheet": "workspace:*",
    "@cursorless/lib-common": "workspace:*",
    "bootstrap": "^5.3.8",
    "preact": "^10.29.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.4",
    "jest": "^30.4.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-purgecss": "^0.2.13",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
