{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run extension",
      "type": "extensionHost",
      "request": "launch",
      "env": {
        "CURSORLESS_MODE": "development",
        "CURSORLESS_REPO_ROOT": "${workspaceFolder}"
      },
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/app-vscode/dist",
        "--profile=cursorlessDevelopment"
      ],
      "outFiles": ["${workspaceFolder}/**/out/**/*.js"],
      "preLaunchTask": "Build extension",
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    },
    {
      "name": "Extension tests",
      "type": "extensionHost",
      "request": "launch",
      "env": {
        "CURSORLESS_MODE": "test",
        "CURSORLESS_LOG_FAILED": "true",
        "CURSORLESS_REPO_ROOT": "${workspaceFolder}"
      },
      "args": [
        "--profile=cursorlessDevelopment",
        "--extensionDevelopmentPath=${workspaceFolder}/packages/app-vscode/dist",
        "--extensionTestsPath=${workspaceFolder}/packages/test-runner/out/extensionTestsVscode.cjs"
      ],
      "outFiles": ["${workspaceFolder}/**/out/**/*.js"],
      "preLaunchTask": "Build extension and tests",
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    },
    {
      "name": "Extension tests (subset)",
      "type": "extensionHost",
      "request": "launch",
      "env": {
        "CURSORLESS_MODE": "test",
        "CURSORLESS_RUN_TEST_SUBSET": "true",
        "CURSORLESS_LOG_FAILED": "true",
        "CURSORLESS_REPO_ROOT": "${workspaceFolder}"
      },
      "args": [
        "--profile=cursorlessDevelopment",
        "--extensionDevelopmentPath=${workspaceFolder}/packages/app-vscode/dist",
        "--extensionTestsPath=${workspaceFolder}/packages/test-runner/out/extensionTestsVscode.cjs"
      ],
      "outFiles": ["${workspaceFolder}/**/out/**/*.js"],
      "preLaunchTask": "Build extension and tests (subset)",
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    },
    {
      "name": "Update test fixtures",
      "type": "extensionHost",
      "request": "launch",
      "env": {
        "CURSORLESS_MODE": "test",
        "CURSORLESS_TEST_UPDATE_FIXTURES": "true",
        "CURSORLESS_REPO_ROOT": "${workspaceFolder}"
      },
      "args": [
        "--profile=cursorlessDevelopment",
        "--extensionDevelopmentPath=${workspaceFolder}/packages/app-vscode/dist",
        "--extensionTestsPath=${workspaceFolder}/packages/test-runner/out/extensionTestsVscode.cjs"
      ],
      "outFiles": ["${workspaceFolder}/**/out/**/*.js"],
      "preLaunchTask": "Build extension and tests",
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    },
    {
      "name": "Update test fixtures (subset)",
      "type": "extensionHost",
      "request": "launch",
      "env": {
        "CURSORLESS_MODE": "test",
        "CURSORLESS_TEST_UPDATE_FIXTURES": "true",
        "CURSORLESS_RUN_TEST_SUBSET": "true",
        "CURSORLESS_REPO_ROOT": "${workspaceFolder}"
      },
      "args": [
        "--profile=cursorlessDevelopment",
        "--extensionDevelopmentPath=${workspaceFolder}/packages/app-vscode/dist",
        "--extensionTestsPath=${workspaceFolder}/packages/test-runner/out/extensionTestsVscode.cjs"
      ],
      "outFiles": ["${workspaceFolder}/**/out/**/*.js"],
      "preLaunchTask": "Build extension and tests (subset)",
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    }
  ]
}
